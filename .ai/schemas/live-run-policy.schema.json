{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-app.local/schemas/live-run-policy.schema.json",
  "title": "Live Run Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "executionEnabled", "allowedAgents", "allowedSkills", "allowedModes", "allowedUntrackedPaths", "network", "productionFirebase", "gitWrite", "deploy", "nestedExecution", "maxRuntimeSeconds", "maxOutputBytes", "requireApproval", "resultImportMode"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "artifactType": { "const": "live-run-policy" },
    "executionEnabled": { "type": "boolean" },
    "allowedAgents": { "type": "array", "items": { "enum": ["codex"] }, "uniqueItems": true },
    "allowedSkills": { "type": "array", "items": { "enum": ["discuss", "understand", "explain-diff"] }, "minItems": 1, "uniqueItems": true },
    "allowedModes": { "type": "array", "items": { "const": "read-only-analysis" }, "minItems": 1, "uniqueItems": true },
    "allowedUntrackedPaths": { "const": [".ai/runtime/local/", ".ai/runs/"] },
    "network": { "const": false }, "productionFirebase": { "const": false }, "gitWrite": { "const": false }, "deploy": { "const": false }, "nestedExecution": { "const": false },
    "maxRuntimeSeconds": { "type": "integer", "minimum": 1, "maximum": 600 },
    "maxOutputBytes": { "type": "integer", "minimum": 1024, "maximum": 5242880 },
    "requireApproval": { "const": true },
    "resultImportMode": { "const": "manual" }
  }
}
