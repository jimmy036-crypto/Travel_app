{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,

    "types": [
      "vite/client",
      "google.maps"
    ]
  },
  "include": [
    "src",
    "e2e/**/*.ts",
    "playwright.config.ts",
    "vite.config.js",
    "vitest.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dev-dist",
    "coverage",
    "playwright-report",
    "test-results",
    ".firebase"
  ]
}