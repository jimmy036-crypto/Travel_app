  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run test:run && npm run build",
    "dev:emulator": "vite --mode emulator",
    "build:emulator": "vite build --mode emulator",
    "dev:emulator": "vite --mode emulator",
    "emulators": "firebase emulators:start --only database,storage",
    "dev:test": "concurrently -k -n FIREBASE,VITE \"npm run emulators\" \"npm run dev:emulator\""
  },
