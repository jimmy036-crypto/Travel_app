{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-app.local/schemas/decision.schema.json",
  "title": "Travel App Architecture Decision",
  "description": "A machine-readable architecture decision record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "status",
    "context",
    "decision",
    "consequences",
    "alternatives",
    "owners",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^ADR-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["proposed", "accepted", "rejected", "deprecated", "superseded"]
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "consequences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positive", "negative"],
      "properties": {
        "positive": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "negative": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["option", "reasonRejected"],
        "properties": {
          "option": {
            "type": "string",
            "minLength": 1
          },
          "reasonRejected": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "supersedes": {
      "type": ["string", "null"],
      "pattern": "^ADR-[0-9]{3,}$"
    },
    "relatedTasks": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["architect", "codex", "gemini", "reviewer", "qa", "docs", "human"]
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "updatedAt"],
      "properties": {
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "description"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
