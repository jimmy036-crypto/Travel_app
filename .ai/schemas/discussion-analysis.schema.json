{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-app.local/schemas/discussion-analysis.schema.json",
  "title": "Independent Discussion Analysis",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "fixture", "source", "sessionId", "contributionId", "round", "participant", "recommendation", "rationale", "assumptions", "options", "risks", "testsRequired", "evidence", "unknowns", "confidence"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" }, "artifactType": { "type": "string", "const": "discussion-analysis" },
    "fixture": { "type": "boolean" }, "source": { "type": "string", "minLength": 1 },
    "sessionId": { "$ref": "#/$defs/id" }, "contributionId": { "$ref": "#/$defs/id" }, "round": { "type": "string", "const": "independent-analysis" },
    "participant": { "$ref": "#/$defs/identity" },
    "recommendation": { "type": "string", "minLength": 1 },
    "rationale": { "$ref": "#/$defs/strings" }, "assumptions": { "$ref": "#/$defs/strings" }, "options": { "$ref": "#/$defs/strings" },
    "risks": { "$ref": "#/$defs/strings" }, "testsRequired": { "$ref": "#/$defs/strings" },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
    "unknowns": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "strings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "identity": { "type": "object", "additionalProperties": false, "required": ["participantId", "agent", "role"], "properties": { "participantId": { "$ref": "#/$defs/id" }, "agent": { "type": "string", "enum": ["codex", "claude", "gemini", "human"] }, "role": { "type": "string", "enum": ["architect", "engineer", "analyst", "reviewer", "qa", "docs", "approver"] } } },
    "evidence": { "type": "object", "additionalProperties": false, "required": ["claim", "path", "symbol"], "properties": { "claim": { "type": "string", "minLength": 1 }, "path": { "$ref": "#/$defs/path" }, "symbol": { "type": "string", "minLength": 1 } } },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:[\\\\/])(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?![A-Za-z][A-Za-z0-9+.-]*:).+$" }
  }
}
