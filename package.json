{
  "name": "travel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator",
    "dev:e2e": "vite --mode emulator --host 127.0.0.1 --port 4174 --strictPort --force",
    "emulators": "firebase emulators:start --only auth,database,storage",
    "emulators:e2e": "firebase emulators:start --only auth,database,storage --project demo-travel-e2e",
    "firebase:version": "node scripts/firebase-cli-version.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "agent:guardrails": "node scripts/agent-guardrails.mjs",
    "agent:verify": "node scripts/agent-verify.mjs fast",
    "agent:verify:e2e": "node scripts/agent-verify.mjs e2e",
    "agent:verify:all": "node scripts/agent-verify.mjs all",
    "verify:fast": "npm run agent:guardrails && npm run agent:verify",
    "verify:full": "npm run agent:guardrails && npm run agent:verify:all",
    "task:preflight": "node scripts/task-preflight.mjs",
    "ai:artifacts:test": "node --test scripts/ai/learning-artifact.test.mjs",
    "ai:artifacts:validate": "node scripts/ai/learning-artifact.mjs validate-all",
    "ai:artifacts:render": "node scripts/ai/learning-artifact.mjs render-all",
    "ai:artifacts:check": "node scripts/ai/learning-artifact.mjs check",
    "ai:adapters:test": "node --test scripts/ai/agent-adapter.test.mjs",
    "ai:adapters:check": "node scripts/ai/agent-adapter.mjs check",
    "ai:adapters:doctor": "node scripts/ai/agent-adapter.mjs doctor",
    "ai:invocations:validate": "node scripts/ai/agent-adapter.mjs validate-all",
    "ai:discussion:test": "node --test scripts/ai/discussion.test.mjs",
    "ai:discussion:validate": "node scripts/ai/discussion.mjs validate-all",
    "ai:discussion:check": "node scripts/ai/discussion.mjs check",
    "ai:runner:test": "node --test scripts/ai/agent-runner.test.mjs",
    "ai:runner:check": "node scripts/ai/agent-runner.mjs check",
    "ai:runner:doctor": "node scripts/ai/agent-runner.mjs doctor",
    "ai:runner:validate": "node scripts/ai/agent-runner.mjs validate-all"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@vis.gl/react-google-maps": "^1.8.3",
    "firebase": "^12.15.0",
    "framer-motion": "^12.35.1",
    "html2canvas-pro": "^2.2.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.27",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "15.22.4",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
