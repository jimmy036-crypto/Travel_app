{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-app.local/schemas/human-approval.schema.json",
  "title": "Human Discussion Approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "fixture", "source", "sessionId", "decisionId", "actorRole", "action", "comment", "approvedAt"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" }, "artifactType": { "const": "human-approval" },
    "fixture": { "type": "boolean" }, "source": { "type": "string", "minLength": 1 },
    "sessionId": { "$ref": "#/$defs/id" }, "decisionId": { "$ref": "#/$defs/id" },
    "actorRole": { "const": "human" }, "action": { "enum": ["approve", "reject", "request-changes"] },
    "comment": { "type": "string", "minLength": 1 }, "approvedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": { "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" } }
}
