{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-app.local/schemas/agent-invocation.schema.json",
  "title": "Travel App Agent Invocation Plan",
  "description": "A non-executing, plan-only invocation for a canonical Travel App learning skill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactType",
    "agent",
    "skill",
    "mode",
    "workingDirectory",
    "canonicalSkill",
    "adapterPath",
    "arguments",
    "permissions",
    "expectedOutput",
    "execution"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "artifactType": { "const": "agent-invocation" },
    "agent": { "enum": ["codex", "claude", "gemini"] },
    "skill": { "enum": ["understand", "explain-diff"] },
    "mode": { "const": "plan-only" },
    "workingDirectory": { "$ref": "#/$defs/repositoryPath" },
    "canonicalSkill": { "$ref": "#/$defs/repositoryPath" },
    "adapterPath": { "$ref": "#/$defs/repositoryPath" },
    "arguments": {
      "oneOf": [
        { "$ref": "#/$defs/understandArguments" },
        { "$ref": "#/$defs/explainDiffArguments" }
      ]
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filesystem", "network", "productionFirebase", "gitWrite", "deploy"],
      "properties": {
        "filesystem": { "const": "read-only" },
        "network": { "const": false },
        "productionFirebase": { "const": false },
        "gitWrite": { "const": false },
        "deploy": { "const": false }
      }
    },
    "expectedOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "draftPath"],
      "properties": {
        "schema": { "$ref": "#/$defs/repositoryPath" },
        "draftPath": { "$ref": "#/$defs/repositoryPath" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "reason", "interactiveInvocation", "headlessArgvPreview"],
      "properties": {
        "enabled": { "const": false },
        "reason": { "type": "string", "minLength": 1 },
        "interactiveInvocation": { "type": "string", "minLength": 1 },
        "headlessArgvPreview": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:[\\\\/])(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?![Jj][Aa][Vv][Aa][Ss][Cc][Rr][Ii][Pp][Tt]:)(?![Ff][Ii][Ll][Ee]:)(?![Hh][Tt][Tt][Pp][Ss]?:).+$"
    },
    "understandArguments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic"],
      "properties": { "topic": { "type": "string", "minLength": 1 } }
    },
    "explainDiffArguments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseRef", "headRef"],
      "properties": {
        "baseRef": { "type": "string", "minLength": 1 },
        "headRef": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "skill": { "const": "understand" } } },
      "then": { "properties": { "arguments": { "$ref": "#/$defs/understandArguments" } } }
    },
    {
      "if": { "properties": { "skill": { "const": "explain-diff" } } },
      "then": { "properties": { "arguments": { "$ref": "#/$defs/explainDiffArguments" } } }
    }
  ]
}
