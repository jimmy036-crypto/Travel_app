{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-app.local/schemas/discussion-critique.schema.json",
  "title": "Discussion Cross Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "fixture", "source", "sessionId", "contributionId", "round", "participant", "reviewedContributionIds", "agreements", "disagreements", "unsupportedAssumptions", "missedRisks", "questions", "revisedRecommendation", "evidence", "confidence"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" }, "artifactType": { "const": "discussion-critique" },
    "fixture": { "type": "boolean" }, "source": { "type": "string", "minLength": 1 },
    "sessionId": { "$ref": "#/$defs/id" }, "contributionId": { "$ref": "#/$defs/id" }, "round": { "const": "cross-review" },
    "participant": { "$ref": "#/$defs/identity" },
    "reviewedContributionIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "agreements": { "$ref": "#/$defs/strings" }, "disagreements": { "$ref": "#/$defs/strings" },
    "unsupportedAssumptions": { "$ref": "#/$defs/strings" }, "missedRisks": { "$ref": "#/$defs/strings" }, "questions": { "$ref": "#/$defs/strings" },
    "revisedRecommendation": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "strings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "identity": { "type": "object", "additionalProperties": false, "required": ["participantId", "agent", "role"], "properties": { "participantId": { "$ref": "#/$defs/id" }, "agent": { "enum": ["codex", "claude", "gemini", "human"] }, "role": { "enum": ["architect", "engineer", "analyst", "reviewer", "qa", "docs", "approver"] } } },
    "evidence": { "type": "object", "additionalProperties": false, "required": ["claim", "path", "symbol"], "properties": { "claim": { "type": "string", "minLength": 1 }, "path": { "$ref": "#/$defs/path" }, "symbol": { "type": "string", "minLength": 1 } } },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:[\\\\/])(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?![A-Za-z][A-Za-z0-9+.-]*:).+$" }
  }
}
